{
  "Platform": {
    "ApplicationName": "DaemonPlatform",
    "Role": "AdminApi",
    "NodeName": "",
    "EnvironmentName": "Production"
  },
  "Quartz": {
    "SchedulerName": "DaemonPlatformCluster",
    "InstanceId": "API-AUTO",
    "Provider": "SqlServer",
    "Schema": "quartz",
    "TablePrefix": "QRTZ_",
    "ThreadCount": 2,
    "MisfireThresholdSeconds": 60,
    "ClusterCheckinIntervalSeconds": 15,
    "DriverDelegateType": "Quartz.Impl.AdoJobStore.SqlServerDelegate, Quartz",
    "OverwriteExistingJobs": false,
    "ConnectionStringTemplate": "Server=SQL-QUARTZ-CLUSTER;Database=DaemonQuartz;User ID=svc_daemon_quartz_runtime;Password={secret:QuartzRuntimeDbPassword};Encrypt=True;TrustServerCertificate=False;"
  },
  "ExecutionHistory": {
    "Enabled": true,
    "Schema": "poc",
    "TableName": "JobExecutionLog",
    "ConnectionStringTemplate": "Server=SQL-QUARTZ-CLUSTER;Database=DaemonQuartz;User ID=svc_daemon_quartz_runtime;Password={secret:QuartzRuntimeDbPassword};Encrypt=True;TrustServerCertificate=False;"
  },
  "DemoJobs": {
    "FastCron": "0 0/1 * * * ?",
    "SlowCron": "0 0/3 * * * ?",
    "SlowDurationSeconds": 150
  },
  "Secrets": {
    "LogicalToCredentialTarget": {
      "QuartzRuntimeDbPassword": "orquestator/quartz/sql/runtime/password"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    },
    "File": {
      "Enabled": true,
      "Path": "logs/api/daemon-admin-api.jsonl"
    }
  }
}
